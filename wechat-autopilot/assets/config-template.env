# WeChat AutoPilot Configuration
# 复制此文件为 .env 并填入你的真实配置

# ==================== 微信配置 ====================
# 微信公众号 AppID (从 mp.weixin.qq.com 获取)
WECHAT_APP_ID=wx_xxxxxxxxxxxxxxxx

# 微信公众号 AppSecret (从开发密钥页面重置获取)
WECHAT_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IP 白名单 (已预设共享代理，无需修改)
WECHAT_IP_WHITELIST=155.94.132.10

# ==================== 文生图配置 ====================
# TuziAPI 密钥 (从 tuziapi.com 注册获取)
IMAGE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 生图模型 (推荐 nanobanana，成本低)
IMAGE_MODEL=nanobanana

# 图片风格 (可选: mondo, realistic, illustration)
IMAGE_STYLE=mondo

# 图片尺寸
IMAGE_SIZE=1024x1024

# 每篇文章配图数量 (封面+正文)
IMAGE_COUNT=3

# ==================== 内容配置 ====================
# 资讯关键词 (英文逗号分隔)
NEWS_KEYWORDS=AI,人工智能,科技,创业

# 目标语言 (zh-CN: 中文, en: 英文)
TARGET_LANGUAGE=zh-CN

# 写作风格 (standup: 脱口秀, news: 新闻评论, edu: 科普教育, biz: 商业分析)
WRITING_STYLE=standup

# 文章长度 (short: 短, medium: 中等, long: 长)
ARTICLE_LENGTH=medium

# 是否标原创 (true/false)
MARK_ORIGINAL=true

# 是否开启评论 (true/false)
ENABLE_COMMENT=true

# 是否仅粉丝可评论 (true/false)
FANS_ONLY_COMMENT=false

# ==================== 定时配置 ====================
# 定时发布时间 (24小时制，逗号分隔多个时间)
POST_SCHEDULE=10:00,18:00

# 时区
TIMEZONE=Asia/Shanghai

# ==================== 高级配置 ====================
# 每次抓取新闻数量
NEWS_FETCH_COUNT=10

# 文章保留天数 (自动清理旧文章)
ARTICLE_RETENTION_DAYS=30

# 调试模式 (true/false)
DEBUG_MODE=false

# 日志级别 (debug, info, warning, error)
LOG_LEVEL=info
